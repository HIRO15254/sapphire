{
  "name": "sapphire",
  "version": "1.0.0",
  "description": "Sapphire - ポーカーセッションを記録・分析するアプリケーション",
  "keywords": [
    "poker",
    "session-tracker",
    "sapphire",
    "nextjs",
    "react",
    "typescript",
    "trpc",
    "drizzle-orm",
    "mantine",
    "postgresql",
    "pwa",
    "fullstack"
  ],
  "author": "Sapphire Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HIRO15254/sapphire"
  },
  "bugs": {
    "url": "https://github.com/HIRO15254/sapphire/issues"
  },
  "homepage": "https://github.com/HIRO15254/sapphire#readme",
  "private": false,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push:test": "cross-env DATABASE_URL=\"postgresql://postgres:postgres@localhost:5432/sapphire_test\" SKIP_ENV_VALIDATION=true drizzle-kit push",
    "db:push:all": "bun run db:push && bun run db:push:test",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbo",
    "preview": "bun run build && cross-env NODE_ENV=production bun run start",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "pwa:icons": "node scripts/generate-pwa-icons.js"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@mantine/core": "^8.3.9",
    "@mantine/dates": "^8.3.9",
    "@mantine/hooks": "^8.3.9",
    "@mantine/modals": "^8.3.9",
    "@mantine/notifications": "^8.3.9",
    "@mantine/tiptap": "^8.3.9",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-query": "^5.90.12",
    "@tiptap/extension-link": "^2.27.1",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/react": "^2.27.1",
    "@tiptap/starter-kit": "^2.27.1",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.41.0",
    "mantine-form-zod-resolver": "^1.3.0",
    "next": "^15.5.7",
    "next-auth": "^5.0.0-beta.30",
    "postgres": "^3.4.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.6",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.19.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^2.1.9",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.30.6",
    "jsdom": "^27.3.0",
    "playwright": "^1.57.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  }
}
