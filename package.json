{
  "name": "sapphire",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cd src-tauri && cargo test -- --test-threads=1",
    "test:e2e": "cd e2e-tests && npm run test:clean",
    "test:all": "bun run test:run && bun run test:rust",
    "test:full": "bun run test:coverage && bun run test:rust && bun run test:e2e",
    "tauri": "tauri",
    "generate-icons": "cd src-tauri && tauri icon ../src-tauri/icons/icon.png",
    "lint": "biome check . && cd src-tauri && cargo clippy -- -D warnings",
    "lint:fix": "biome check . --write --unsafe && cd src-tauri && cargo clippy --fix --allow-dirty --allow-staged",
    "format": "biome format . --write && cd src-tauri && cargo fmt",
    "format:check": "biome format . && cd src-tauri && cargo fmt --check",
    "format:check:ci": "biome format . --diagnostic-level=warn && cd src-tauri && cargo fmt --check"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@mantine/core": "^8.3.0",
    "@mantine/form": "^8.3.1",
    "@mantine/hooks": "^8.3.0",
    "@mantine/notifications": "^8.3.1",
    "@tabler/icons-react": "^3.34.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.9.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.2",
    "@biomejs/biome": "^2.2.3",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^2.1.8",
    "axe-core": "^4.10.3",
    "happy-dom": "^18.0.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^25.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^2.1.8"
  }
}
